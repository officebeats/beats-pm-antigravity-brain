# Antigravity Ignore
# ========================================
# PERFORMANCE OPTIMIZATION
# ========================================
# These patterns control what the AI indexes on startup.
# Goal: Keep context window lean, load data on-demand.
#
# NOTE: This does NOT prevent access—the AI can still
# read these files when explicitly asked.
# ========================================

# Standard dev excludes
node_modules/
dist/
build/
.git/
.DS_Store
Thumbs.db
.venv/

# Large media files
*.mp4
*.mov
*.wav
*.mp3
*.zip
*.tar.gz

# ========================================
# SYMLINK DOUBLE-SCAN PREVENTION
# ========================================
# .agent/ is the SINGLE canonical source of truth.
# All of these are symlinks back to .agent/ and cause
# 2x-6x duplicate scanning of agents, skills, workflows.
# Blocking them saves ~500KB+ of redundant indexing.
#
# Works on macOS/Linux (real symlinks) and Windows
# (where Git stores symlinks as text files unless
# core.symlinks=true).
.agents/
_agent/
_agents/

# .gemini/ subdirs are symlinks to .agent/ content
.gemini/agents/
.gemini/skills/
.gemini/workflows/
.gemini/templates/

# .claude/ contains symlinks to .agent/ content
.claude/

# .kilocode/ contains symlinks to .agent/ content
.kilocode/

# ========================================
# NON-ESSENTIAL ROOT FILES
# ========================================
# Reference docs — AI can read on-demand if asked
AGENT_FLOW.md
README.md
CHANGELOG.md
Feb24.md
Feb25.md

# ========================================
# SYSTEM BUILD ARTIFACTS & TOOLING
# ========================================
# These are apps/tools, not PM working files
system/task-viewer/
system/docs-site/
system/pm-dashboard/
system/dashboard/
system/test_logs/
system/extensions/
system/examples/
system/reports/
system/debug_schema.txt

# ----------------------------------------
# LARGE DATA FOLDERS (Exclude from initial indexing)
# ----------------------------------------
/3. Meetings/archive/**
!/3. Meetings/archive/.gitkeep

# ----------------------------------------
# ACTIVE WORKING FILES (ALWAYS ACCESSIBLE)
# ----------------------------------------
# These are intentionally NOT ignored:
